# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=cspm
POSTGRES_USER=cspm_user
POSTGRES_PASSWORD=changeme_strong_password

# ── Constructed automatically by docker-compose (do not change) ─────────────
# DATABASE_URL is set in docker-compose.yml using the above values

# ── Security Keys ────────────────────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CSPM_ENCRYPT_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# JWT token expiry in hours
JWT_EXPIRE_HOURS=24

# ── Email / SMTP (for alerts & password resets) ──────────────────────────────
# Pick ONE provider below and fill in the values.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  BREVO (recommended — free 300 emails/day, no credit card)              │
# │  Sign up: brevo.com → Settings → SMTP & API → Generate SMTP key        │
# │                                                                          │
# │  SMTP_HOST=smtp-relay.brevo.com                                          │
# │  SMTP_PORT=587                                                           │
# │  SMTP_USER=your-brevo-login@email.com                                   │
# │  SMTP_PASSWORD=xsmtpsib-xxxxxxxx...                                      │
# │  SMTP_FROM=your-brevo-login@email.com                                   │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  GMAIL (free — 500 emails/day, requires App Password)                   │
# │  Setup: enable 2FA → myaccount.google.com/apppasswords                  │
# │                                                                          │
# │  SMTP_HOST=smtp.gmail.com                                                │
# │  SMTP_PORT=587                                                           │
# │  SMTP_USER=your-project@gmail.com                                       │
# │  SMTP_PASSWORD=xxxx xxxx xxxx xxxx  (16-char app password)              │
# │  SMTP_FROM=your-project@gmail.com                                       │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  RESEND (free — 100 emails/day)                                          │
# │  Sign up: resend.com → API Keys → Generate                              │
# │                                                                          │
# │  SMTP_HOST=smtp.resend.com                                               │
# │  SMTP_PORT=465                                                           │
# │  SMTP_USER=resend                                                        │
# │  SMTP_PASSWORD=re_xxxxxxxx...                                            │
# │  SMTP_FROM=onboarding@resend.dev  (or your verified domain)             │
# └──────────────────────────────────────────────────────────────────────────┘
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=YOUR_BREVO_LOGIN_EMAIL
SMTP_PASSWORD=YOUR_BREVO_SMTP_KEY
SMTP_FROM=YOUR_BREVO_LOGIN_EMAIL

# ── Frontend URL (used in password reset email links) ────────────────────────
FRONTEND_URL=http://localhost:5173

# ── App ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
