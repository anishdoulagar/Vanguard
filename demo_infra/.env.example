# ─────────────────────────────────────────────────────────────────────────────
#  Vanguard CSPM — Demo Infrastructure Credentials
#
#  SETUP (one time):
#    cp demo_infra/.env.example demo_infra/.env
#    # then fill in the values below in demo_infra/.env
#
#  demo_infra/.env is gitignored — your credentials will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure Service Principal ───────────────────────────────────────────────────
# Create one with:
#   az ad sp create-for-rbac --name cspm-demo --role Contributor \
#     --scopes /subscriptions/<your-subscription-id>
# The output gives you appId (CLIENT_ID), password (CLIENT_SECRET), tenant (TENANT_ID)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── AWS IAM User ──────────────────────────────────────────────────────────────
# Create a user in AWS Console → IAM → Users → Add user → Programmatic access
# Attach policy: AdministratorAccess (or a targeted CSPM test policy)
# Then generate access keys under Security credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Vanguard API (for automated demo provisioning) ────────────────────────────
# Used by: python3 demo_infra/demo_manager.py demo
#
# WHY: The demo script creates all demo teams/users/accounts via the Vanguard REST
# API. To do that it must authenticate first — so it needs YOUR existing superadmin
# account (the one you created during first-time setup). It uses this account to
# create the demo teams (alice/bob/carol/etc.) on your behalf.
#
# MUST BE SUPERADMIN: the team-creation endpoint requires superadmin role.
# An admin account will not work.
VANGUARD_API_URL=http://localhost:8000
VANGUARD_ADMIN_USERNAME=your_superadmin_username
VANGUARD_ADMIN_PASSWORD=your_superadmin_password
